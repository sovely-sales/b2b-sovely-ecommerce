{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sovely-backend.onrender.com/api/$1"
    },
    {
      "source": "/avatars/(.*)",
      "destination": "https://sovely-backend.onrender.com/avatars/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "https://sovely-backend.onrender.com/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}